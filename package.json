{
  "name": "qmd-prover",
  "version": "0.1.0",
  "description": "A Quarto-based agentic mathematical proof workflow",
  "type": "module",
  "bin": {
    "qmd-prover": "skills/qmd-prover/scripts/qmd-prover.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "build:test-fixtures": "tsc --project tsconfig.fixtures.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "npm run build && npm run build:test-fixtures && node --import tsx --test tests/*.test.ts",
    "inspect": "node skills/qmd-prover/scripts/qmd-prover.js inspect project",
    "install:skill": "npm run build && tsx tooling/install-skill.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.13.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
